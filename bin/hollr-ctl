#!/usr/bin/env python3
"""hollr read-aloud control — bind a global hotkey to `hollr-ctl pause|resume|stop`."""
import os, sys
sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from lib import control  # noqa: E402

ACTIONS = {"pause": control.pause, "resume": control.resume, "stop": control.stop}

def main() -> None:
    action = sys.argv[1] if len(sys.argv) > 1 else ""
    fn = ACTIONS.get(action)
    if not fn:
        print("usage: hollr-ctl pause|resume|stop", file=sys.stderr); sys.exit(2)
    print(fn())

if __name__ == "__main__":
    main()
