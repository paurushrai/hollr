#!/usr/bin/env python3
"""hollr prerequisite check — run `hollr-doctor` (or /hollr doctor)."""
import os, sys
sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from lib import doctor  # noqa: E402

def main() -> None:
    checks = doctor.check_all()
    for c in checks:
        mark = "OK " if c.ok else ("!! " if c.required else "-- ")
        line = f"{mark} {c.label}"
        if not c.ok and c.detail:
            line += f"  ({c.detail})"
        print(line)
        if not c.ok and c.fix:
            print(f"      fix: {c.fix}")
    ok = doctor.all_required_ok(checks)
    print("\nhollr: all required prerequisites present" if ok
          else "\nhollr: missing required prerequisites (see !! above)")
    sys.exit(0 if ok else 1)

if __name__ == "__main__":
    main()
